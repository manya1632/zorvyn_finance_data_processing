# ============================================================
# Finance Data Processing API — Environment Variables
# Copy this file to .env and fill in the values.
# ===========================================================

# --- Required ---

# DATABASE_URL (required) - PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/finance_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_db

# JWT_SECRET (required) - Secret key for signing JWTs (minimum 32 characters)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# --- Optional ---

# JWT_EXPIRES_IN (optional, default: 24h) - JWT expiry duration (e.g. 24h, 7d, 3600)
JWT_EXPIRES_IN=24h

# PORT (optional, default: 3000) - HTTP server port
PORT=3000

# NODE_ENV (optional, default: development) - Runtime environment (development|production|test)
NODE_ENV=development

# LOG_LEVEL (optional, default: info) - Winston log level (error|warn|info|debug)
LOG_LEVEL=info

# ALLOWED_ORIGINS (optional, default: *) - Comma-separated list of CORS allowed origins
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# CACHE_TTL_SECONDS (optional, default: 60) - Dashboard cache TTL in seconds
CACHE_TTL_SECONDS=60

# RATE_LIMIT_WINDOW_MS (optional, default: 900000) - Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX (optional, default: 100) - Maximum requests per window per IP (global)
RATE_LIMIT_MAX=100

# AUTH_RATE_LIMIT_MAX (optional, default: 10) - Maximum auth requests per window per IP
AUTH_RATE_LIMIT_MAX=10
