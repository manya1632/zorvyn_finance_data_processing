generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(VIEWER)
  status    UserStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  records FinancialRecord[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model FinancialRecord {
  id          String     @id @default(uuid())
  amount      Decimal    @db.Decimal(15, 2)
  type        RecordType
  category    String
  date        DateTime
  notes       String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([deletedAt])
  @@index([type, category, date])
  @@map("financial_records")
}

model AuditLog {
  id           String      @id @default(uuid())
  actorId      String
  actorRole    String
  action       AuditAction
  resourceType String
  resourceId   String
  diff         Json
  timestamp    DateTime    @default(now())

  @@index([timestamp])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
